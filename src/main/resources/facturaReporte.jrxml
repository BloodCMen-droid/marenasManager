<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="facturaReporte"
              language="java"
              pageWidth="595"
              pageHeight="842"
              columnWidth="535"
              leftMargin="30"
              rightMargin="30"
              topMargin="20"
              bottomMargin="20">

    <field name="facturaId" class="java.lang.Long"/>
    <field name="fechaEmision" class="java.time.LocalDateTime"/>
    <field name="metodoPago" class="java.lang.String"/>
    <field name="clienteNombre" class="java.lang.String"/>
    <field name="clienteDni" class="java.lang.String"/>
    <field name="clienteTelefono" class="java.lang.String"/>
    <field name="mesaNumero" class="java.lang.Integer"/>
    <field name="meseroNombre" class="java.lang.String"/>
    <field name="productoNombre" class="java.lang.String"/>
    <field name="cantidad" class="java.lang.Integer"/>
    <field name="precioUnit" class="java.math.BigDecimal"/>
    <field name="subtotalLinea" class="java.math.BigDecimal"/>
    <field name="subtotal" class="java.math.BigDecimal"/>
    <field name="igv" class="java.math.BigDecimal"/>
    <field name="total" class="java.math.BigDecimal"/>

    <title>
        <band height="120">
            <staticText>
                <reportElement x="0" y="0" width="535" height="30"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[MARENAS GRILL]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="30" width="535" height="20"/>
                <textElement textAlignment="Center">
                    <font size="10"/>
                </textElement>
                <text><![CDATA[RUC: 20601234567]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="55" width="535" height="20"/>
                <textElement textAlignment="Center">
                    <font size="13" isBold="true"/>
                </textElement>
                <text><![CDATA[BOLETA DE VENTA ELECTRONICA]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="80" width="100" height="15"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[N Comprobante:]]></text>
            </staticText>
            <textField>
                <reportElement x="100" y="80" width="150" height="15"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{facturaId}.toString()]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="300" y="80" width="80" height="15"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Metodo Pago:]]></text>
            </staticText>
            <textField>
                <reportElement x="380" y="80" width="155" height="15"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{metodoPago}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="0" y="100" width="80" height="15"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Fecha:]]></text>
            </staticText>
            <textField>
                <reportElement x="80" y="100" width="200" height="15"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{fechaEmision}.toString()]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="110">
            <!-- DATOS CLIENTE -->
            <staticText>
                <reportElement x="0" y="0" width="535" height="15"/>
                <textElement><font size="10" isBold="true"/></textElement>
                <text><![CDATA[DATOS DEL CLIENTE]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="16" width="70" height="13"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Nombre:]]></text>
            </staticText>
            <textField>
                <reportElement x="70" y="16" width="250" height="13"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{clienteNombre}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="0" y="31" width="70" height="13"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[DNI:]]></text>
            </staticText>
            <textField>
                <reportElement x="70" y="31" width="150" height="13"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{clienteDni}]]></textFieldExpression>
            </textField>

            <!-- DATOS PEDIDO -->
            <staticText>
                <reportElement x="0" y="50" width="535" height="15"/>
                <textElement><font size="10" isBold="true"/></textElement>
                <text><![CDATA[DATOS DEL PEDIDO]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="67" width="60" height="13"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Mesa:]]></text>
            </staticText>
            <textField>
                <reportElement x="60" y="67" width="80" height="13"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{mesaNumero}.toString()]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="200" y="67" width="80" height="13"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Atendido por:]]></text>
            </staticText>
            <textField>
                <reportElement x="280" y="67" width="255" height="13"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{meseroNombre}]]></textFieldExpression>
            </textField>

            <!-- ENCABEZADOS TABLA -->
            <staticText>
                <reportElement x="0" y="90" width="230" height="20"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[PRODUCTO]]></text>
            </staticText>
            <staticText>
                <reportElement x="230" y="90" width="70" height="20"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[CANT.]]></text>
            </staticText>
            <staticText>
                <reportElement x="300" y="90" width="110" height="20"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[PRECIO]]></text>
            </staticText>
            <staticText>
                <reportElement x="410" y="90" width="125" height="20"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[SUBTOTAL]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="18">
            <textField>
                <reportElement x="0" y="0" width="230" height="18"/>
                <box><pen lineWidth="0.3"/></box>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{productoNombre}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="230" y="0" width="70" height="18"/>
                <box><pen lineWidth="0.3"/></box>
                <textElement textAlignment="Center"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{cantidad}.toString()]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="300" y="0" width="110" height="18"/>
                <box><pen lineWidth="0.3"/></box>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA["S/ " + $F{precioUnit}.toString()]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="410" y="0" width="125" height="18"/>
                <box><pen lineWidth="0.3"/></box>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA["S/ " + $F{subtotalLinea}.toString()]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="70">
            <staticText>
                <reportElement x="300" y="10" width="110" height="15"/>
                <textElement textAlignment="Right"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Subtotal:]]></text>
            </staticText>
            <textField>
                <reportElement x="410" y="10" width="125" height="15"/>
                <textElement textAlignment="Right"><font size="10"/></textElement>
                <textFieldExpression><![CDATA["S/ " + $F{subtotal}.toString()]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="300" y="28" width="110" height="15"/>
                <textElement textAlignment="Right"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[IGV (18%):]]></text>
            </staticText>
            <textField>
                <reportElement x="410" y="28" width="125" height="15"/>
                <textElement textAlignment="Right"><font size="10"/></textElement>
                <textFieldExpression><![CDATA["S/ " + $F{igv}.toString()]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="300" y="48" width="110" height="18"/>
                <textElement textAlignment="Right"><font size="12" isBold="true"/></textElement>
                <text><![CDATA[TOTAL:]]></text>
            </staticText>
            <textField>
                <reportElement x="410" y="48" width="125" height="18"/>
                <textElement textAlignment="Right"><font size="12" isBold="true"/></textElement>
                <textFieldExpression><![CDATA["S/ " + $F{total}.toString()]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>